---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  narrow?: boolean;
  image?: string;
}

const { title, description, narrow = false, image } = Astro.props;

const SITE = 'Statecraft Systems';
const DEFAULT_DESCRIPTION = 'Statecraft Systems designs and operates systems of cooperation and sovereignty.';
const SITE_URL = 'https://statecraft.systems';

const pageTitle = title === SITE ? SITE : `${title} — ${SITE}`;
const metaDescription = description || DEFAULT_DESCRIPTION;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImage = new URL(image || '/og-default.png', SITE_URL).href;

const pathname = Astro.url.pathname;
const currentPath = pathname.slice(1).replace(/\/$/, "");
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <div class="site-wrapper">
      <header>
        <div class="header-inner">
          <div class="logo">
            <a href="/">Statecraft Systems</a>
          </div>
          
          <button class="mobile-nav-toggle" aria-expanded="false" aria-controls="main-nav">
            Menu
          </button>

          <nav id="main-nav">
            <ul class="nav-links">
              <li><a href="/" class={currentPath === "" ? "active" : ""}>Home</a></li>
              <li><a href="/work" class={currentPath === "work" ? "active" : ""}>Work</a></li>
              <li><a href="/approach" class={currentPath === "approach" ? "active" : ""}>Approach</a></li>
              <li><a href="/services" class={currentPath === "services" ? "active" : ""}>Services</a></li>
              <li><a href="/about" class={currentPath === "about" ? "active" : ""}>About</a></li>
              <li><a href="/contact" class={currentPath === "contact" ? "active" : ""}>Contact</a></li>
            </ul>
          </nav>
        </div>
      </header>

      <main class={narrow ? "narrow" : ""}>
        <slot />
      </main>

      <footer>
        <div class="footer-inner">
          <div class="footer-col">
            <h4>Network</h4>
            <ul>
              <li><a href="https://modernminuteman.net" target="_blank" rel="noopener noreferrer">Modern Minuteman</a></li>
              <li><a href="https://hayescanon.org" target="_blank" rel="noopener noreferrer">Hayes Canon</a></li>
              <li><a href="https://capablefew.com" target="_blank" rel="noopener noreferrer">Capable Few</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Tools</h4>
            <ul>
              <li>sd-core</li>
              <li>spikes.sh</li>
              <li>beats</li>
              <li>werk-cli</li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Contact</h4>
            <ul>
              <li><a href="mailto:contact@statecraft.systems">contact@statecraft.systems</a></li>
              <li><a href="https://moritzbierling.com" target="_blank" rel="noopener noreferrer">moritzbierling.com</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>&copy; {new Date().getFullYear()} Statecraft Systems</span>
          <span>Operative Tradition</span>
        </div>
      </footer>
    </div>

    <!-- Spikes feedback widget · one project per site for unified inbox -->
    <script is:inline src="https://spikes.sh/widget.js" data-project="statecraft-systems" data-endpoint="https://spikes.sh/spikes" data-theme="dark" data-position="bottom-right" data-color="#e85a2d"></script>

    <script>
      // Mobile navigation toggle
      const mobileNavToggle = document.querySelector('.mobile-nav-toggle');
      const navLinks = document.querySelector('.nav-links');

      if (mobileNavToggle && navLinks) {
        mobileNavToggle.addEventListener('click', () => {
          const isExpanded = mobileNavToggle.getAttribute('aria-expanded') === 'true';
          mobileNavToggle.setAttribute('aria-expanded', String(!isExpanded));
          navLinks.classList.toggle('is-open');
          
          // Update button text
          mobileNavToggle.textContent = isExpanded ? 'Menu' : 'Close';
        });
      }
    </script>
  </body>
</html>
