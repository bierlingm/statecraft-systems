---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" narrow={true}>
  <section class="intro">
    <h1>Contact</h1>
    <p class="long-form">
      Reaching out is a question of structural alignment. We work with decision-makers who will build, have hard conversations about what is real, and commit to advance. If the principles and the work resonate, we can determine if there is a fit.
    </p>
    <div class="rule"></div>
  </section>

  <section class="section">
    <div class="contact-block">
      <p><strong>Email:</strong> <a href="mailto:contact@statecraft.systems">contact@statecraft.systems</a></p>
    </div>
  </section>
</BaseLayout>
