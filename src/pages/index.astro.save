---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Statecraft Systems designs and operates systems of cooperation and sovereignty.">
  <div class="intro">
    <h1>Statecraft Systems</h1>
    <p>A small studio designing systems, brands, and experiences that support sovereign cooperation and formation.</p>
  </div>

  <section class="section">
    <p>
      Statecraft Systems focuses on the practical design of architectures that enable cooperation, responsibility, and the formation of individuals and communities. It works across formats—training, retreats, systems design, branding, and institutional infrastructure—to quietly support projects that embody these principles.
    </p>
    <p>
      Most of the studio's activity is expressed through collaborations and partner projects. The studio itself remains intentionally minimal, serving as an organizing principle for work in service of sovereign cooperation.
    </p>
  </section>

  <section class="section">
    <h2>Projects</h2>
    <div class="projects-grid">
      <div class="project-block">
        <h3>Modern Minuteman</h3>
        <p>Training and formation for decentralized civic resilience, emphasizing practical skills and local sovereignty.</p>
        <a href="https://modernminuteman.net" target="_blank" rel="noopener noreferrer">Visit →</a>
      </div>
      <div class="project-block">
        <h3>The Field Company</h3>
        <p>Creates environments where men practice clarity, resilience, and responsibility through shared experience. Small, curated retreats combining physical challenge, structured dialogue, and exposure to nature.</p>
        <a href="https://fieldcompany.org" target="_blank" rel="noopener noreferrer">Visit →</a>
      </div>
    </div>
  </section>

</BaseLayout>
