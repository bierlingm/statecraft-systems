---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Work">
  <section class="intro">
    <h1>Work & Productions</h1>
    <p class="long-form">
      Productions built for aligned partners, interventions that produced structural change, and tools built for our own use and shared with the network.
    </p>
    <div class="rule"></div>
  </section>

  <section class="section">
    <h2>Productions</h2>
    <div class="production-block">
      <h3 class="production-title">Decide / Act 2026</h3>
      <div>
        <p>The National Law Institute's first operating cadence. A vouched online convening for sixty-four operators — Brief, Sessions, Roster, Pulse — that converts orientation into 90-day commitments and the network they run on. June 1 – July 10, 2026.</p>
        <a href="/decideact/" class="production-link">statecraft.systems/decideact</a>
      </div>
    </div>
    <div class="production-block">
      <h3 class="production-title">Narrative Commons</h3>
      <div>
        <p>Public infrastructure for extracting, verifying, and presenting competing narrative frameworks. Makes narrative structure visible, verifiable, and navigable across a thousand incoherent voices.</p>
        <a href="https://narrativecommons.org" target="_blank" rel="noopener noreferrer" class="production-link">narrativecommons.org</a>
      </div>
    </div>
    <div class="production-block">
      <h3 class="production-title">Hayes Canon</h3>
      <div>
        <p>Production for Brandon Hayes.</p>
        <a href="https://hayescanon.org" target="_blank" rel="noopener noreferrer" class="production-link">hayescanon.org</a>
      </div>
    </div>
    <div class="production-block">
      <h3 class="production-title">Modern Minuteman</h3>
      <div>
        <p>Training for civic resilience.</p>
        <a href="https://modernminuteman.net" target="_blank" rel="noopener noreferrer" class="production-link">modernminuteman.net</a>
      </div>
    </div>
    <div class="production-block">
      <h3 class="production-title">Capable Few</h3>
      <div>
        <p>Own project.</p>
        <a href="https://capablefew.com" target="_blank" rel="noopener noreferrer" class="production-link">capablefew.com</a>
      </div>
    </div>
    <div class="production-block">
      <h3 class="production-title">The Field Company</h3>
      <div>
        <p>Formation through shared challenge.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Interventions</h2>
    <div class="production-block">
      <h3 class="production-title">Skinner Layne</h3>
      <div>
        <p>Introduction to Claude Code led to team training, product building, scientific work, and acceleration of fundraising efforts.</p>
      </div>
    </div>
    <div class="production-block">
      <h3 class="production-title">Noah (The Meta Father)</h3>
      <div>
        <p>Rebuilt platform architecture and moved off Kajabi.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Programs</h2>
    <ul class="structural-list">
      <li><strong>Exosphere:</strong> Multi-week to two-month intensives.</li>
      <li><strong>Volta:</strong> Weekend retreat format.</li>
      <li><strong>Modern Minuteman:</strong> Structured cohort programs.</li>
    </ul>
  </section>

  <section class="section">
    <h2>Tools</h2>
    <div class="grid-2">
      <div class="offering-card">
        <h3>sd-core</h3>
        <p>Structural dynamics framework.</p>
      </div>
      <div class="offering-card">
        <h3>spikes.sh</h3>
        <p>Rapid prototyping.</p>
        <a href="https://spikes.sh">spikes.sh</a>
      </div>
      <div class="offering-card">
        <h3>beats</h3>
        <p>Knowledge and memory system.</p>
      </div>
      <div class="offering-card">
        <h3>werk-cli</h3>
        <p>Workspace management.</p>
      </div>
    </div>
  </section>
</BaseLayout>
