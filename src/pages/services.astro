---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services">
  <section class="intro">
    <h1>Services</h1>
    <p class="long-form">
      The natural path: the CEO gets personal value first, then brings in the team.
    </p>
    <div class="rule"></div>
  </section>

  <section class="section">
    <h2>Individual Track</h2>
    <div class="grid-3">
      <div class="offering-card">
        <h3>Unlock Session</h3>
        <div class="offering-meta">
          <span>~3hrs</span>
          <span>$1,500</span>
        </div>
        <p>Initial structural assessment and orientation.</p>
      </div>
      
      <div class="offering-card">
        <h3>Personal Stack Build</h3>
        <div class="offering-meta">
          <span>2 weeks</span>
          <span>$5,000</span>
        </div>
        <p>Building real tools on your workflows, on your devices.</p>
      </div>
      
      <div class="offering-card">
        <h3>Sparring Partner</h3>
        <div class="offering-meta">
          <span>Monthly</span>
          <span>$1,500 - $2,500</span>
        </div>
        <p>Ongoing structural and technical support for decision making.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Team Track</h2>
    <div class="grid-2">
      <div class="offering-card">
        <h3>Discovery</h3>
        <div class="offering-meta">
          <span>$3,000 - $5,000</span>
        </div>
        <p>Organizational assessment and capability mapping.</p>
      </div>
      
      <div class="offering-card">
        <h3>Build</h3>
        <div class="offering-meta">
          <span>$8,000 - $15,000</span>
        </div>
        <p>Developing specific tools and systems for team workflows.</p>
      </div>
      
      <div class="offering-card">
        <h3>Train</h3>
        <div class="offering-meta">
          <span>$2,500 - $5,000</span>
        </div>
        <p>Formation programs to make the team AI-native.</p>
      </div>
      
      <div class="offering-card">
        <h3>Retainer</h3>
        <div class="offering-meta">
          <span>Monthly</span>
          <span>$2,000 - $4,000</span>
        </div>
        <p>Ongoing operational support and capability expansion.</p>
      </div>
    </div>
  </section>
</BaseLayout>
